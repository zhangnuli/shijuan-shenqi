{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "试卷神器",
  "version": "0.1.0",
  "identifier": "com.shijuan.shenqi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "试卷神器",
        "width": 1280,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src ipc: http://ipc.localhost https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/**/*"],
    "windows": {
      "wix": {
        "language": "zh-CN",
        "upgradeCode": "c428413d-43e1-5cc0-9005-1748d403972d"
      },
      "nsis": {
        "languages": ["SimpChinese"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyODU0QzczNTU1N0I0NDAKUldSQXRGZFZjMHlGWWpBMnJ2cy9nWkZjVS9FbkR3eGFmYnNaMk1WOHlqSkhHekg4blBVSXpxRTYK",
      "endpoints": [
        "https://github.com/zhangnuli/shijuan-shenqi/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
